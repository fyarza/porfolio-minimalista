---
import Section from "../Section.astro"
import { work as workDefault } from "@cv"
import type { CV as cvType } from "@/cv.d"

interface Props {
  cvData?: cvType
  title?: string
}

const { cvData, title = "Experiencia laboral" } = Astro.props
const work = cvData?.work ?? workDefault
---

<Section title={title}>
  <ul>
    {
      work.map(
        ({ name, startDate, endDate, position, summary, highlights, url }) => {
          const start = new Date(startDate)
          const startLabel = start.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
          })
          const endLabel =
            endDate != null
              ? new Date(endDate).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                })
              : "Present"

          return (
            <li>
              <article>
                <header>
                  <div>
                    <h3>
                      <a href={url} title={`Ver ${name}`} target="_blank">
                        {name}
                      </a>
                    </h3>
                    <h4>{position}</h4>
                  </div>

                  <div>
                    <time 
                      datetime={startDate}
                      data-title={startDate}>
                        {startLabel}
                    </time>
                    {" - "}
                    <time 
                      datetime={endDate}
                      data-title={endDate}>
                        {endLabel}
                    </time>
                  </div>
                </header>

                <footer>
                  <p>{summary}</p>
                  {Array.isArray(highlights) && highlights.length > 0 && (
                    <ul class="highlights">
                      {highlights.map((highlight) => (
                        <li>{highlight}</li>
                      ))}
                    </ul>
                  )}
                </footer>
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: #111;
  }

  article a {
    color: #111;
  }

  article a:hover {
    text-decoration: underline;
  }

  article h4 {
    color: #222;
    font-weight: 400;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  footer {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .highlights {
    list-style: disc;
    margin: 0;
    padding-left: 20px;
    display: grid;
    gap: 4px;
  }

  .highlights li {
    color: #444;
    font-size: 0.85rem;
    line-height: 1.4;
  }

  time {
    color: #555;
    font-size: 0.85rem;
    min-width: 102px;
    cursor: default;
  }

  [data-title]:hover:after {
    opacity: 1;
    transition: all 0.1s ease-in-out 0.5s;
    visibility: visible;
  }

  [data-title]:after {
    content: attr(data-title);
    background-color: #333;
    color: #fff;
    font-size: .75rem;
    font-family: Menlo, Monaco, Lucida Console, "Courier New", monospace;;
    position: absolute;
    padding: .2rem .5rem;
    bottom: -1.4rem;
    left: 50%;
    white-space: nowrap;
    box-shadow: 1px 1px 1px #222222;
    opacity: 0;
    border: 1px solid #111111;
    z-index: 99999;
    visibility: hidden;
    border-radius: 6px;
  }

  [data-title] {
    position: relative;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
