---
import Section from "../Section.astro"
import LinkedIn from "@/icons/LinkedIn.astro"
import GitHub from "@/icons/GitHub.astro"
import { basics as defaultBasics } from "@cv"
import type { CV } from "@/cv.d"

interface Props {
  cvData?: CV
  title?: string
  showEmail?: boolean
  emailLabel?: string
}

const {
  cvData,
  title = "Encuéntrame en",
  showEmail = true,
  emailLabel = "Correo",
} = Astro.props

const { profiles, email, name } = cvData?.basics ?? defaultBasics

const PROFILE_ICONS: Record<string, typeof LinkedIn> = {
  LinkedIn,
  GitHub,
}
---

<Section title={title}>
  <div class="links">
    {
      profiles.map(({ network, url }) => {
        const Icon = PROFILE_ICONS[network]
        return (
          <a
            href={url}
            class="btn"
            target="_blank"
            rel="me noopener noreferrer"
            title={`Perfil de ${name} en ${network}`}
          >
            {Icon && <Icon />}
            <span>{network}</span>
          </a>
        )
      })
    }
    {
      showEmail && (
        <a
          href={`mailto:${email}`}
          class="btn btn-outline"
          title={`Correo a ${name}`}
        >
          <span>{emailLabel}</span>
        </a>
      )
    }
    <slot />
  </div>
</Section>

<style>
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .links :global(.btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: #111;
    color: #fff;
    padding: 0.55rem 1rem;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .links :global(.btn:hover) {
    background: #333;
    text-decoration: none;
  }

  .links :global(.btn-outline) {
    background: transparent;
    color: #111;
    border: 1px solid #ddd;
  }

  .links :global(.btn-outline:hover) {
    background: #f5f5f5;
  }

  @media (width <= 700px) {
    .links {
      flex-direction: column;
    }

    .links :global(.btn) {
      justify-content: center;
    }
  }
</style>
