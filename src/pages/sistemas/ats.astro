---
import cvSistemas from "../../../cv_sistemas.json"
import type { CV } from "@/cv.d"

const { basics, education, projects, skills, work } = cvSistemas as CV

const formatDate = (value: string | null) => {
  if (!value) return "Presente"
  return new Date(value).toLocaleDateString("es-ES", {
    year: "numeric",
    month: "short",
  })
}

const uniqueSkills = Array.from(
  new Set(
    skills.flatMap((skill) =>
      [skill.name, ...(Array.isArray(skill.keywords) ? skill.keywords : [])].map(
        (item) => item.trim()
      )
    )
  )
).filter(Boolean)
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <title>CV ATS Sistemas - {basics.name}</title>
    <style>
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        color: #111;
        line-height: 1.4;
        background: #fff;
      }

      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 28px 24px 32px;
      }

      h1,
      h2,
      h3 {
        margin: 0;
      }

      h1 {
        font-size: 1.8rem;
      }

      .role {
        margin-top: 4px;
        color: #333;
        font-size: 1rem;
      }

      .contact {
        margin-top: 12px;
        font-size: 0.95rem;
      }

      section {
        margin-top: 20px;
      }

      section h2 {
        font-size: 1rem;
        border-bottom: 1px solid #ddd;
        padding-bottom: 4px;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }

      article {
        margin-bottom: 14px;
      }

      article header {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: baseline;
      }

      article h3 {
        font-size: 1rem;
      }

      article p {
        margin: 6px 0;
      }

      ul {
        margin: 0;
        padding-left: 18px;
      }

      li {
        margin-bottom: 4px;
      }

      .skills {
        font-size: 0.95rem;
      }

      .featured {
        border: 1px solid #ddd;
        padding: 12px 14px;
        border-radius: 4px;
        background: #fafafa;
      }

      .featured h3 {
        margin-bottom: 6px;
      }

      @media print {
        main {
          padding: 0;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <div>
        <h1>{basics.name}</h1>
        <p class="role">{basics.label}</p>
        <div class="contact">
          <div>Email: {basics.email}</div>
          <div>Teléfono: {basics.phone}</div>
          <div>Ubicación: {basics.location.city}, {basics.location.region}</div>
          {basics.profiles.map(({ network, url }) => (
            <div>{network}: {url}</div>
          ))}
        </div>
      </div>

      <section>
        <h2>Resumen profesional</h2>
        <p>{basics.summary}</p>
      </section>

      <section>
        <h2>Experiencia laboral</h2>
        {work.map((job) => (
          <article>
            <header>
              <h3>{job.position} - {job.name}</h3>
              <span>{formatDate(job.startDate)} - {formatDate(job.endDate)}</span>
            </header>
            <p>{job.summary}</p>
            {Array.isArray(job.highlights) && job.highlights.length > 0 && (
              <ul>
                {job.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </section>

      <section>
        <h2>Habilidades</h2>
        <p class="skills">{uniqueSkills.join(", ")}</p>
      </section>

      <section>
        <h2>Educación</h2>
        {education.map((item) => (
          <article>
            <header>
              <h3>{item.area} - {item.institution}</h3>
              <span>{formatDate(item.startDate)} - {formatDate(item.endDate)}</span>
            </header>
          </article>
        ))}
      </section>

      <section>
        <h2>Proyecto destacado — LECOMP B2B Portal (Profit Plus 200)</h2>
        {projects
          .filter((p) => p.name === "LECOMP B2B Portal")
          .map((project) => (
            <article class="featured">
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              {Array.isArray(project.highlights) && project.highlights.length > 0 && (
                <ul>
                  {project.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              )}
            </article>
          ))}
      </section>

      <section>
        <h2>Otros proyectos relevantes</h2>
        {projects
          .filter((p) => p.name !== "LECOMP B2B Portal")
          .map((project) => (
            <article>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              {Array.isArray(project.highlights) && project.highlights.length > 0 && (
                <ul>
                  {project.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              )}
            </article>
          ))}
      </section>
    </main>
  </body>
</html>
