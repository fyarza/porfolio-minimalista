---
import Layout from "@/layouts/Layout.astro"

import About from "@/components/sections/About.astro"
import Education from "@/components/sections/Education.astro"
import Experience from "@/components/sections/Experience.astro"
import Hero from "@/components/sections/Hero.astro"
import Projects from "@/components/sections/Projects.astro"
import Skills from "@/components/sections/Skills.astro"
import ExternalLinks from "@/components/sections/ExternalLinks.astro"
import KeyboardManager from "@/components/KeyboardManager.astro"

import { basics } from "@cv"
const { name, label } = basics
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "")
---

<Layout title={`Portafolio de ${name} - ${label}`} canonicalPath="/">
  <main>
    <Hero />
    <About />
    <Experience />
    <Education />
    <Projects />
    <Skills />
    <ExternalLinks title="Encuéntrame en">
      <a href={`${baseUrl}/sistemas/`} class="btn btn-outline" title="Portafolio orientado a sistemas y Profit Plus">
        Portafolio Sistemas
      </a>
    </ExternalLinks>
  </main>

  <KeyboardManager />
</Layout>

<style>
  main {
    padding: 4rem;
    margin: auto;
    width: 100%;
  }

  @media (width <= 700px) {
    main {
      padding: 2rem;
    }
  }
</style>
