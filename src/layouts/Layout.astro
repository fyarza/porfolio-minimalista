---
import { basics as defaultBasics } from "@cv"
import type { CV } from "@/cv.d"
import { absoluteUrl, truncateDescription } from "@/lib/seo"

interface Props {
  title: string
  cvData?: CV
  description?: string
  ogTitle?: string
  ogImage?: string
  ogImageAlt?: string
  canonicalPath?: string
  lang?: string
  robots?: string
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>
}

const {
  title,
  cvData,
  description,
  ogTitle,
  ogImage,
  ogImageAlt,
  canonicalPath,
  lang = "es",
  robots,
  jsonLd,
} = Astro.props

const basics = cvData?.basics ?? defaultBasics
const social = cvData?.social
const { image, summary, name } = basics

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "")
const imagePath = image.startsWith("/") ? `${baseUrl}${image}` : `${baseUrl}/${image}`
const faviconPath = `${baseUrl}/favicon.svg`

const metaDescription = truncateDescription(
  description ?? social?.description ?? summary
)
const pageOgTitle = ogTitle ?? social?.title ?? title
const ogImagePath = ogImage ?? social?.image ?? "/og-default.png"
const ogImageUrl = absoluteUrl(ogImagePath)
const ogImageAltText = ogImageAlt ?? social?.imageAlt ?? pageOgTitle
const canonicalUrl = absoluteUrl(canonicalPath ?? Astro.url.pathname)

const siteHostname = new URL(canonicalUrl).hostname
const locale = lang === "en" ? "en_US" : "es_VE"
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width" />
    <meta name="author" content={name} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="icon" type="image/svg+xml" href={faviconPath} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preload" as="image" href={imagePath} />

    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={name} />
    <meta property="og:locale" content={locale} />
    <meta property="og:title" content={pageOgTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAltText} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:domain" content={siteHostname} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={pageOgTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAltText} />

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      "Courier New",
      Courier,
      monospace;
    background: #fff;
    letter-spacing: -0.025rem;
  }

  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  p {
    color: #666;
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
  }

  .print {
    display: none !important;
  }

  @media print {
    .no-print {
      display: none !important;
    }

    .print {
      display: block !important;
    }

    astro-dev-toolbar {
      display: none !important;
    }

    article {
      break-inside: avoid;
    }
  }
</style>
